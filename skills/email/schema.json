{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Email Skill Action",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "read_inbox",
        "list_unread",
        "read_email",
        "send_email",
        "reply_email",
        "auto_reply"
      ]
    },
    "message_id": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "body": {
      "type": "string"
    }
  },
  "required": ["action"]
}
