{
  "name": "whatsapp",
  "description": "Send and receive WhatsApp messages. Supports multiple providers including Direct WhatsApp Web, Meta Cloud API, Twilio, and CallMeBot.",
  "version": "1.0.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "send_message",
          "send_media",
          "check_status",
          "get_config"
        ],
        "description": "The WhatsApp action to perform"
      },
      "to": {
        "type": "string",
        "description": "Recipient phone number in E.164 format (e.g. +1234567890)"
      },
      "message": {
        "type": "string",
        "description": "Text content of the message to send"
      },
      "media_url": {
        "type": "string",
        "description": "Public URL of media to send (image, video, document)"
      },
      "message_sid": {
        "type": "string",
        "description": "Twilio Message SID for status check"
      }
    },
    "required": [
      "action"
    ]
  },
  "extra_settings": {
    "title": "WhatsApp",
    "description": "Send WhatsApp messages via Twilio. Requires a free Twilio account.",
    "provider": "twilio",
    "auth": {
      "type": "api_key",
      "fields": [
        {
          "key": "account_sid",
          "label": "Twilio Account SID",
          "placeholder": "ACxxxxxxxxxx"
        },
        {
          "key": "auth_token",
          "label": "Twilio Auth Token",
          "placeholder": "your-auth-token",
          "secret": true
        },
        {
          "key": "from_number",
          "label": "Twilio WhatsApp Number",
          "placeholder": "+14155238886",
          "hint": "Use +14155238886 for Twilio sandbox"
        }
      ],
      "statusEndpoint": "/api/skills/whatsapp/status",
      "saveEndpoint": "/api/skills/whatsapp/configure",
      "saveMethod": "POST"
    }
  }
}