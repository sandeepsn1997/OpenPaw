{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WhatsApp Skill Action",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "send_message",
        "send_media",
        "check_status",
        "get_config"
      ],
      "description": "The WhatsApp action to perform"
    },
    "to": {
      "type": "string",
      "description": "Recipient phone number in E.164 format (e.g. +1234567890)",
      "pattern": "^\\+[1-9]\\d{1,14}$"
    },
    "message": {
      "type": "string",
      "description": "Text content of the message to send",
      "maxLength": 4096
    },
    "media_url": {
      "type": "string",
      "description": "Public URL of media to send (image, video, document)",
      "format": "uri"
    },
    "message_sid": {
      "type": "string",
      "description": "Twilio Message SID for checking delivery status"
    }
  },
  "required": [
    "action"
  ],
  "additionalProperties": false
}