{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stock_analysis_input",
  "type": "object",
  "properties": {
    "tickers": {
      "type": "array",
      "description": "Optional ticker list. For Indian swing trade requests, omit to use curated NSE large caps.",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9.\-]{1,20}$"
      },
      "maxItems": 30
    },
    "analysis_window": {
      "type": "string",
      "enum": ["1w", "1m", "3m", "6m", "1y"],
      "default": "3m"
    },
    "risk_profile": {
      "type": "string",
      "enum": ["conservative", "balanced", "aggressive"],
      "default": "balanced"
    },
    "market": {
      "type": "string",
      "enum": ["india", "global"],
      "default": "india"
    },
    "objective": {
      "type": "string",
      "enum": ["swing_trade", "position_trade"],
      "default": "swing_trade"
    },
    "top_n": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 5
    }
  },
  "additionalProperties": false
}
